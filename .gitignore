# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# large video/model files — never commit these
pro-videos/
public/pro-videos/
public/clip-previews/
# copied from node_modules/@ffmpeg/core by scripts/copy-ffmpeg-core.mjs at
# install time; too large to commit but needed by the deployed bundle
public/ffmpeg/
# yt-dlp self-contained binary fetched by scripts/fetch-yt-dlp.mjs at install
# time; also carried into the Vercel function bundle via next.config.ts
bin/
*.mp4
*.task
*.zip
# Phase E test fixtures: tiny libx264 mp4 used by liveSwingBatchExtractor's
# mp4box demux/remux test. Regenerate via the recipe in the test file.
!__tests__/fixtures/*.mp4

# python
__pycache__/
*.pyc
__MACOSX/
.claude/

# rtmpose / yolo model weights.
# Broad default: ignore *.onnx / *.pt anywhere in the repo so stray
# downloads aren't tracked.
# Exception: railway-service/models/yolo11n.* is committed intentionally,
# because Railway's cold-start YOLO autodownload was silently failing
# ("Racket detected 0 / N" on every clip). Shipping the ~15MB of weights
# in-repo is the reliability win — the alternative is a build-phase
# prefetch in nixpacks, which adds a moving part we can't easily debug.
*.onnx
*.onnx.data
*.pt
# Phase 5: ONNX weights for the browser pose stack are downloaded by
# scripts/download-models.mjs into public/models/ at install time. The
# broad *.onnx rule above already covers this, but call it out
# explicitly so future contributors who tweak the broader rules don't
# accidentally start tracking the 40-60 MB of weights.
public/models/*.onnx
public/models/*.onnx.data
!railway-service/models/yolo11n.onnx
!railway-service/models/yolo11n.onnx.data
!railway-service/models/yolo11n.pt
